# ── WhatsApp ──────────────────────────────────────────────
GIGA_WHATSAPP_BRIDGE_URL=http://localhost:8080
GIGA_WHATSAPP_DB_PATH=./whatsapp-bridge/store/messages.db
GIGA_WHATSAPP_GROUP_JID=123456789@g.us
GIGA_WHATSAPP_POLL_INTERVAL_SECONDS=10

# ── JIRA ──────────────────────────────────────────────────
GIGA_JIRA_URL=https://your-company.atlassian.net
GIGA_JIRA_USERNAME=you@company.com
GIGA_JIRA_API_TOKEN=your_atlassian_api_token
GIGA_JIRA_PROJECT_KEY=PROJ
GIGA_JIRA_DEFAULT_ISSUE_TYPE=Story
GIGA_JIRA_DEFAULT_PRIORITY=Medium
GIGA_JIRA_INTAKE_STATUS=To Do

# ── Parser ────────────────────────────────────────────────
GIGA_PARSER_TYPE=rule_based
# GIGA_ANTHROPIC_API_KEY=sk-ant-...   # Only needed for parser_type=llm

# ── Server ────────────────────────────────────────────────
GIGA_TRANSPORT=stdio
GIGA_HOST=0.0.0.0
GIGA_PORT=8000
