# ── JIRA ──────────────────────────────────────────────────
GIGA_JIRA_URL=https://your-company.atlassian.net
GIGA_JIRA_USERNAME=you@company.com
GIGA_JIRA_API_TOKEN=your_atlassian_api_token
GIGA_JIRA_PROJECT_KEY=PROJ
# GIGA_JIRA_DEFAULT_ISSUE_TYPE=Story
# GIGA_JIRA_DEFAULT_PRIORITY=Medium
# GIGA_JIRA_INTAKE_STATUS=To Do
# GIGA_JIRA_PROCESSED_LABEL=ai-processed

# ── GitHub ────────────────────────────────────────────────
GIGA_GITHUB_TOKEN=<pat with repo+workflow scopes>
GIGA_GITHUB_REPO=<owner/repo>
# GIGA_GITHUB_BASE_BRANCH=main
# GIGA_PIPELINE_HUMAN_GATE=true
# GIGA_PIPELINE_MAX_RETRIES=3
# GIGA_PIPELINE_COMMIT_AUTHOR_NAME=giga-pipeline[bot]
# GIGA_PIPELINE_COMMIT_AUTHOR_EMAIL=giga-pipeline[bot]@users.noreply.github.com

# ── AI / Anthropic ────────────────────────────────────────
GIGA_ANTHROPIC_API_KEY=sk-ant-...
# GIGA_ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # pipeline always uses Sonnet

# ── Auth (Cognito) — leave blank to disable ───────────────
# GIGA_COGNITO_USER_POOL_ID=us-east-1_xxxxx
# GIGA_COGNITO_REGION=us-east-1
# GIGA_COGNITO_CLIENT_ID=your_app_client_id
# GIGA_PUBLIC_URL=https://mcp.example.com

# ── Server ────────────────────────────────────────────────
# GIGA_SERVER_NAME=giga-mcp-server
GIGA_TRANSPORT=stdio              # "stdio" or "streamable-http"
# GIGA_HOST=0.0.0.0
# GIGA_PORT=8000
# GIGA_LOG_FILE=./giga-mcp-server.log
# GIGA_INSPECT=true
